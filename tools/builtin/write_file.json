{
  "name": "write_file",
  "version": "1.0.0",
  "type": "builtin",
  "category": "file",
  "function": {
    "description": "将文本内容写入给定绝对路径的新文件（仅限尚未创建的新文件，不会覆盖已有文件），必要时自动创建父目录。",
    "parameters": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "description": "要创建的新文件的绝对路径（文件不能已存在）" },
        "content": { "type": "string", "description": "要写入文件的文本内容" }
      },
      "required": ["path", "content"]
    }
  },
  "executor": "builtin:write_file",
  "permissions": ["allowWrite", "pathInAllowedDirs"]
}