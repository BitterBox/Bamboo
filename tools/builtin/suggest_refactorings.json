{
  "name": "suggest_refactorings",
  "version": "1.0.0",
  "type": "builtin",
  "category": "code",
  "function": {
    "description": "分析源文件并给出重构建议（长函数、深层嵌套、重复导入等）。",
    "parameters": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "description": "要分析的源文件的绝对路径" }
      },
      "required": ["path"]
    }
  },
  "executor": "builtin:suggest_refactorings",
  "permissions": ["allowRead", "pathInAllowedDirs"]
}