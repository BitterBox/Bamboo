{
  "name": "list_directory",
  "version": "1.0.0",
  "type": "builtin",
  "category": "file",
  "function": {
    "description": "列出给定绝对路径目录中的文件和子目录。",
    "parameters": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "description": "要列出的目录的绝对路径" }
      },
      "required": ["path"]
    }
  },
  "executor": "builtin:list_directory",
  "permissions": ["allowRead", "pathInAllowedDirs"]
}